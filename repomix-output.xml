    async showInterstitial() {
        const sdk = this.game.sdk;
        if (!sdk || !sdk.isReady || !sdk.ysdk?.adv) return Promise.resolve();
        try {
            await sdk.showInterstitial();
        } catch (e) {
            console.warn('Interstitial failed:', e);
